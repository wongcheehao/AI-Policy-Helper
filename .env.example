# =========================
# Backend - LLM + Embeddings
# =========================
EMBEDDING_MODEL=all-MiniLM-L6-v2 # Local embeddings (fast, offline). Use local-384 for deterministic stub embeddings.
LLM_PROVIDER=stub                 # options: stub | openrouter | ollama
LLM_MODEL=openai/gpt-4o-mini      # OpenRouter model slug (used only when LLM_PROVIDER=openrouter).
OLLAMA_HOST=http://ollama:11434   # Used only when LLM_PROVIDER=ollama.

# =========================
# Backend - API Keys
# =========================
OPENROUTER_API_KEY=               # Required only when LLM_PROVIDER=openrouter.

# =========================
# Backend - Retrieval + Chunking
# =========================
VECTOR_STORE=qdrant               # options: qdrant | memory
COLLECTION_NAME=policy_helper     # Qdrant collection / in-memory namespace.
HYBRID_SEARCH_ENABLED=false       # qdrant-only hybrid retrieval (dense + sparse fusion via RRF).
CHUNK_SIZE=256                    # Word-based chunk size for ingestion.
CHUNK_OVERLAP=40                  # Word overlap to reduce context loss at chunk boundaries.

# =========================
# Backend - Reranking + Logging
# =========================
RERANKING_BACKEND=cross-encoder   # options: stub | cross-encoder
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2 # Cross-encoder model for reranking.
LOG_LEVEL=DEBUG                   # Typical values: DEBUG | INFO | WARNING | ERROR.

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_BASE=http://localhost:8000 # Backend API base URL used by the Next.js app.
