# Backend
EMBEDDING_MODEL=all-MiniLM-L6-v2 # real embeddings (offline/local). use local-384 for deterministic stub embeddings
LLM_PROVIDER=stub           # dev/test: stub (offline). demo: openrouter. options: stub | openrouter | ollama
OPENROUTER_API_KEY=         # demo-only: set this when LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini # OpenRouter model name (only used when LLM_PROVIDER=openrouter)
OLLAMA_HOST=http://ollama:11434
VECTOR_STORE=qdrant         # qdrant | memory
COLLECTION_NAME=policy_helper
HYBRID_SEARCH_ENABLED=true  # qdrant-only: dense + sparse fusion via RRF
CHUNK_SIZE=256            # word-based heuristic; tuned for SBERT retrieval
CHUNK_OVERLAP=40          # overlap words to reduce boundary loss

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
